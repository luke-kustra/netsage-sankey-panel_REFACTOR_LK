{
  "name": "netsage-sankey-panel",
  "version": "1.1.3",
  "description": "Sankey Panel Plugin for Grafana",
  "license": "Apache-2.0",
  "repository": "https://github.com/netsage-project/netsage-sankey-panel",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "lint": "eslint --cache --ignore-path ./.gitignore --ext .js,.jsx,.ts,.tsx .",
    "lint:fix": "yarn run lint --fix",
    "server": "docker-compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit"
  },
  "author": {
    "name": "NetSage",
    "email": "khturner2@es.net"
  },
  "dependencies": {
    "@emotion/css": "^11.11.2",
    "@grafana/data": "^13.1.0",
    "@grafana/runtime": "^13.1.0",
    "@grafana/ui": "^13.1.0",
    "d3": ">=7.0.0 <8.0.0",
    "d3-sankey": "0.12.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tslib": "2.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.16.7",
    "@grafana/eslint-config": "^6.0.1",
    "@grafana/tsconfig": "^2.0.0",
    "@swc/core": "^1.3.51",
    "@swc/helpers": "^0.5.0",
    "@swc/jest": "^0.2.23",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/d3": "7.0.0",
    "@types/d3-sankey": "0.11.2",
    "@types/jest": "^29.5.0",
    "@types/lodash": "^4.14.188",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.7.1",
    "eslint-webpack-plugin": "^3.1.1",
    "fork-ts-checker-webpack-plugin": "^7.2.0",
    "glob": "^10.0.0",
    "identity-obj-proxy": "3.0.0",
    "jest": "^29.3.1",
    "jest-environment-jsdom": "^29.3.1",
    "prettier": "^2.5.0",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "1.56.1",
    "sass-loader": "13.2.0",
    "style-loader": "3.3.1",
    "swc-loader": "^0.2.3",
    "esbuild": "^0.24.0",
    "esbuild-register": "^3.6.0",
    "tsconfig-paths": "^4.1.0",
    "typescript": "^5.6.0",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4",
    "webpack-livereload-plugin": "^3.0.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@1.22.10"
}
